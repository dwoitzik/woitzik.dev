---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
---

<PageLayout title="Search" description="Search articles on woitzik.dev">
  <Container>
    <div class="space-y-6">
      <div class="animate font-semibold text-black dark:text-white">Search</div>
      <div id="pagefind-search" class="animate"></div>
    </div>
  </Container>
</PageLayout>

<style is:global>
  #pagefind-search .pagefind-ui__search-input {
    border-radius: 0.75rem !important;
    border: 1px solid rgb(229 229 229) !important;
    background: white !important;
    font-size: 0.875rem !important;
    width: 100% !important;
  }
  .dark #pagefind-search .pagefind-ui__search-input {
    border-color: rgb(38 38 38) !important;
    background: rgb(23 23 23) !important;
    color: white !important;
  }
  #pagefind-search .pagefind-ui__result {
    border-bottom: 1px solid rgb(229 229 229) !important;
    padding: 1rem 0 !important;
  }
  .dark #pagefind-search .pagefind-ui__result {
    border-color: rgb(38 38 38) !important;
  }
  #pagefind-search .pagefind-ui__result-title a {
    color: rgb(0 0 0) !important;
    font-weight: 600 !important;
    text-decoration: none !important;
  }
  .dark #pagefind-search .pagefind-ui__result-title a {
    color: white !important;
  }
  #pagefind-search .pagefind-ui__result-title a:hover {
    color: rgb(14 165 233) !important;
  }
  #pagefind-search .pagefind-ui__button {
    border-radius: 0.5rem !important;
    font-size: 0.875rem !important;
  }
  #pagefind-search .pagefind-ui__message {
    font-size: 0.875rem !important;
  }
</style>

<script is:inline>
  function loadScript(src, id) {
    return new Promise(function (resolve, reject) {
      if (document.getElementById(id)) {
        resolve();
        return;
      }
      var s = document.createElement("script");
      s.id = id;
      s.src = src;
      s.onload = resolve;
      s.onerror = reject;
      document.head.appendChild(s);
    });
  }

  function initSearch() {
    var el = document.getElementById("pagefind-search");
    if (!el) return;
    el.innerHTML = "";

    if (!document.getElementById("pagefind-css")) {
      var link = document.createElement("link");
      link.id = "pagefind-css";
      link.rel = "stylesheet";
      link.href = "/pagefind/pagefind-ui.css";
      document.head.appendChild(link);
    }

    loadScript("/pagefind/pagefind-ui.js", "pagefind-script")
      .then(function () {
        new window.PagefindUI({
          element: "#pagefind-search",
          showSubResults: false,
          showImages: false,
          resetStyles: false,
        });
        el.querySelector("input") && el.querySelector("input").focus();
      })
      .catch(function () {
        el.innerHTML =
          '<p class="text-sm text-neutral-500">Search is not available in this environment.</p>';
      });
  }

  initSearch();
  document.addEventListener("astro:after-swap", initSearch);
</script>
