---
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@consts";
---
<PageLayout title="Legal & Privacy" description="Legal Notice and Privacy Policy">
  <Container>
    <div class="space-y-10 animate">
      
      <section>
        <h1 class="text-3xl font-black text-black dark:text-white tracking-tighter mb-6">
          Legal Notice (Impressum)
        </h1>
        <div class="space-y-4 text-sm text-neutral-700 dark:text-neutral-300 leading-relaxed">
          <p>
            Information provided according to Sec. 5 German Telemedia Act (TMG) / Digitale-Dienste-Gesetz (DDG):
          </p>
          <p>
            <strong>David Woitzik</strong><br />
            Fritz-Räcke-Str. 8<br />
            50354 Hürth<br />
            Germany
          </p>
          <p>
            <strong>Contact:</strong><br />
            Email: <a href={`mailto:${SITE.EMAIL}`} class="text-sky-500 hover:text-sky-600">{SITE.EMAIL}</a>
          </p>
          <p>
            <em>Als Kleinunternehmer im Sinne von § 19 Abs. 1 UStG wird keine Umsatzsteuer berechnet.</em>
          </p>
          <p class="text-xs text-neutral-500 mt-4">
            EU Dispute Resolution: The European Commission provides a platform for online dispute 
            resolution (OS): https://ec.europa.eu/consumers/odr/. I am not willing or obliged to 
            participate in dispute resolution proceedings before a consumer arbitration board.
          </p>
        </div>
      </section>

      <hr class="border-neutral-200 dark:border-neutral-800" />

      <section>
        <h2 class="text-2xl font-black text-black dark:text-white tracking-tighter mb-4">
          Privacy Policy (Datenschutz)
        </h2>
        <div class="space-y-4 text-sm text-neutral-700 dark:text-neutral-300 leading-relaxed">
          <p>
            <strong>1. General Overview</strong><br />
            I take the protection of your personal data very seriously. I treat your personal data 
            confidentially and in accordance with the statutory data protection regulations (GDPR). 
            The use of this website is generally possible without providing personal data.
          </p>
          <p>
            <strong>2. Hosting and Log Files</strong><br />
            This site is hosted on <strong>Vercel Inc.</strong>, 340 Pine Street, Suite 701, 
            San Francisco, CA 94104, USA. The provider automatically collects and stores information 
            in server log files which your browser transmits automatically. These are: browser type 
            and version, operating system used, referrer URL, hostname of the accessing computer, 
            and time of the server request. This data is not merged with other data sources. For 
            details, see <a href="https://vercel.com/legal/privacy-policy" 
            class="text-sky-500 hover:text-sky-600" target="_blank" rel="noopener noreferrer">
            Vercel's privacy policy</a>.
          </p>
          <p>
            <strong>3. Cookies & Analytics</strong><br />
            This website does not use any tracking cookies or third-party analytics tools.
          </p>
          <p>
            <strong>4. Contacting me via Email</strong><br />
            If you send me inquiries via email, your details from the email, including the contact 
            details you provided there, will be stored by me for the purpose of processing the 
            inquiry and in case of follow-up questions. I will not share this information without 
            your consent.
          </p>
        </div>
      </section>

    </div>
  </Container>
</PageLayout>